generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  BKASH
  NAGAD
  ROCKET
  MOBILE_BANKING
  CREDIT_CARD
  DEBIT_CARD
  BANK_ACCOUNT
  CASH
  OTHER
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum SubscriptionType {
  MONTHLY
  YEARLY
  QUARTERLY
  WEEKLY
  LIFETIME
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
  LIFETIME
}

enum LoanStatus {
  ACTIVE
  PAID_OFF
  DEFAULTED
}

enum BudgetPeriod {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  phone        String?
  avatar       String?
  currency     String   @default("BDT")
  timezone     String   @default("Asia/Dhaka")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts        Account[]
  transactions    Transaction[]
  creditCards     CreditCard[]
  creditCardLoans CreditCardLoan[]
  subscriptions   Subscription[]
  budgets         Budget[]
  categories      Category[]
  tags            Tag[]
  aiParseLogs     AIParseLog[]
  aiSettings      AISettings?
  chatMessages    ChatMessage[]
  aiTaskConfigs   AITaskConfig[]
  journalEntries  JournalEntry[]
  insights        Insight[]
  debts           Debt[]

  @@map("users")
}

model Account {
  id        String      @id @default(cuid())
  userId    String
  name      String
  type      AccountType
  balance   Decimal     @default(0) @db.Decimal(15, 2)
  currency  String      @default("BDT")
  icon      String?
  color     String?
  isActive  Boolean     @default(true)
  isDefault Boolean     @default(false)
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, name, type])
  @@index([userId, type])
  @@map("accounts")
}

model Category {
  id        String          @id @default(cuid())
  userId    String?
  name      String
  icon      String?
  color     String?
  type      TransactionType
  parentId  String?
  isDefault Boolean         @default(false)
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       Category?     @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[]    @relation("CategoryTree")
  transactions Transaction[]
  budgets      Budget[]

  @@unique([userId, name, type])
  @@index([userId, type])
  @@map("categories")
}

model Tag {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String?
  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, name])
  @@map("tags")
}

model Transaction {
  id             String          @id @default(cuid())
  userId         String
  accountId      String
  categoryId     String?
  type           TransactionType
  amount         Decimal         @db.Decimal(15, 2)
  currency       String          @default("BDT")
  description    String
  note           String?
  date           DateTime        @default(now())
  isRecurring    Boolean         @default(false)
  metadata       Json?
  creditCardId   String?
  subscriptionId String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account      Account       @relation(fields: [accountId], references: [id], onDelete: Restrict)
  category     Category?     @relation(fields: [categoryId], references: [id])
  tags         Tag[]
  creditCard   CreditCard?   @relation(fields: [creditCardId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([userId, date])
  @@index([userId, type])
  @@index([userId, categoryId])
  @@map("transactions")
}

model CreditCard {
  id              String    @id @default(cuid())
  userId          String
  name            String
  lastFourDigits  String?
  cardType        String?
  creditLimit     Decimal   @db.Decimal(15, 2)
  currentBalance  Decimal   @default(0) @db.Decimal(15, 2)
  availableCredit Decimal   @db.Decimal(15, 2)
  billingDay      Int?
  dueDay          Int?
  interestRate    Decimal?  @db.Decimal(5, 2)
  annualFee       Decimal?  @db.Decimal(10, 2)
  isActive        Boolean   @default(true)
  color           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  loans        CreditCardLoan[]
  transactions Transaction[]
  payments     CreditCardPayment[]

  @@index([userId])
  @@map("credit_cards")
}

model CreditCardLoan {
  id                String     @id @default(cuid())
  creditCardId      String
  userId            String
  name              String
  principalAmount   Decimal    @db.Decimal(15, 2)
  outstandingAmount Decimal    @db.Decimal(15, 2)
  interestRate      Decimal    @db.Decimal(5, 2)
  totalInstallments Int
  paidInstallments  Int        @default(0)
  monthlyEMI        Decimal    @db.Decimal(15, 2)
  startDate         DateTime
  endDate           DateTime
  status            LoanStatus @default(ACTIVE)
  notes             String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  creditCard   CreditCard          @relation(fields: [creditCardId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  installments LoanInstallment[]
  payments     LoanPayment[]

  @@index([creditCardId])
  @@index([userId, status])
  @@map("credit_card_loans")
}

model LoanInstallment {
  id               String   @id @default(cuid())
  loanId           String
  installmentNo    Int
  principalPortion Decimal  @db.Decimal(15, 2)
  interestPortion  Decimal  @db.Decimal(15, 2)
  totalPayment     Decimal  @db.Decimal(15, 2)
  outstandingAfter Decimal  @db.Decimal(15, 2)
  dueDate          DateTime
  paidDate         DateTime?
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())

  loan CreditCardLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([loanId, installmentNo])
  @@index([loanId, status])
  @@map("loan_installments")
}

model LoanPayment {
  id          String   @id @default(cuid())
  loanId      String
  amount      Decimal  @db.Decimal(15, 2)
  paymentDate DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())

  loan CreditCardLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId, paymentDate])
  @@map("loan_payments")
}

model CreditCardPayment {
  id           String   @id @default(cuid())
  creditCardId String
  amount       Decimal  @db.Decimal(15, 2)
  paymentDate  DateTime @default(now())
  notes        String?
  createdAt    DateTime @default(now())

  creditCard CreditCard @relation(fields: [creditCardId], references: [id], onDelete: Cascade)

  @@index([creditCardId, paymentDate])
  @@map("credit_card_payments")
}

model Subscription {
  id              String              @id @default(cuid())
  userId          String
  name            String
  description     String?
  amount          Decimal             @db.Decimal(15, 2)
  currency        String              @default("BDT")
  billingCycle    SubscriptionType
  status          SubscriptionStatus  @default(ACTIVE)
  startDate       DateTime
  endDate         DateTime?
  nextBillingDate DateTime?
  autoRenew       Boolean             @default(true)
  category        String?
  website         String?
  email           String?
  logo            String?
  notes           String?
  color           String?
  icon            String?
  isLifetimeDeal  Boolean             @default(false)
  purchasePrice   Decimal?            @db.Decimal(15, 2)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId, status])
  @@index([userId, nextBillingDate])
  @@map("subscriptions")
}

model Budget {
  id         String       @id @default(cuid())
  userId     String
  categoryId String?
  name       String
  amount     Decimal      @db.Decimal(15, 2)
  spent      Decimal      @default(0) @db.Decimal(15, 2)
  period     BudgetPeriod @default(MONTHLY)
  startDate  DateTime
  endDate    DateTime?
  isActive   Boolean      @default(true)
  alertAt    Int?
  notes      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId, period, startDate])
  @@index([userId, isActive])
  @@map("budgets")
}

model AIParseLog {
  id           String   @id @default(cuid())
  userId       String
  rawInput     String
  parsedResult Json
  confidence   Float?
  wasAccepted  Boolean  @default(false)
  provider     String?
  model        String?
  latencyMs    Int?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("ai_parse_logs")
}

model AISettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  activeProvider  String   @default("")
  fallbackProvider String  @default("")
  activeModel     String   @default("")
  fallbackModel   String   @default("")
  apiKeys         Json     @default("{}")
  fetchedModels   Json     @default("{}")
  preferences     Json     @default("{\"autoParse\":true,\"showConfidence\":true,\"enableChat\":true,\"disableLocalFallback\":true}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_settings")
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // "user" or "assistant"
  content   String
  provider  String?
  model     String?
  tokens    Int?
  mode      String?  // "coach" | "debt_manager" | "analyst"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("chat_messages")
}

// Multi-currency support
model Currency {
  id          String   @id @default(cuid())
  code        String   @unique // "BDT", "USD", "CAD"
  name        String   // "Bangladeshi Taka", "US Dollar", etc.
  symbol      String   @default("৳") // "$", "৳", "C$"
  rateToBase  Decimal  @db.Decimal(15, 6) // 1 unit of this currency = X in base (BDT)
  isBase      Boolean  @default(false) // BDT is base
  lastUpdated DateTime @default(now())
  createdAt   DateTime @default(now())

  @@map("currencies")
}

// AI router task configuration per user
model AITaskConfig {
  id          String   @id @default(cuid())
  userId      String
  taskType    String   // "parser" | "chat" | "insight" | "debt_analysis"
  provider    String   // "openai" | "openrouter" | "custom" | "opencode-zen" | etc.
  model       String   // "gpt-4.1" | "claude-3" | etc.
  temperature Decimal? @default(0.7) @db.Decimal(3, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taskType])
  @@map("ai_task_configs")
}

// AI Journal Entry - free-form text with AI extraction
model JournalEntry {
  id          String   @id @default(cuid())
  userId      String
  rawText     String   // The free-form journal text
  extractedTxs Json?    // AI-extracted transactions array
  summary     String?  // AI-generated summary
  sentiment   String?  // "positive" | "neutral" | "negative"
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("journal_entries")
}

// AI-generated insights
model Insight {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "spending_pattern" | "risk_alert" | "savings_tip" | "debt_stress" | "financial_health"
  title       String
  content     String
  severity    String   @default("info") // "info" | "warning" | "critical"
  metadata    Json?    // scores, percentages, related data
  isRead      Boolean  @default(false)
  provider    String?
  model       String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, createdAt])
  @@index([userId, isRead])
  @@map("insights")
}

// Enhanced debt model - supports credit cards, personal loans, informal debt
model Debt {
  id                String     @id @default(cuid())
  userId            String
  name              String     // "Visa Card" | "Personal Loan" | "Owed to Rahim"
  type              String     // "credit_card" | "personal_loan" | "installment" | "informal"
  calculationMode   String     @default("reducing_balance") // "reducing_balance" | "static"
  principalAmount   Decimal    @db.Decimal(15, 2)
  outstandingAmount Decimal    @db.Decimal(15, 2)
  interestRate      Decimal    @default(0) @db.Decimal(5, 2)
  tenure          Int?        // number of months/periods (null for revolving credit)
  fixedEMI        Decimal?    @db.Decimal(15, 2) // for static mode
  monthlyDue      Decimal?    @db.Decimal(15, 2) // calculated monthly due
  interestPortion Decimal?    @db.Decimal(15, 2) // interest portion of current payment
  startDate         DateTime
  endDate           DateTime?
  dueDay            Int?        // day of month for due date
  creditLimit       Decimal?    @db.Decimal(15, 2) // for credit cards
  lastFourDigits    String?
  lenderName        String?     // for informal/personal loans: "Friend", "Bank", etc.
  color             String?
  status            LoanStatus  @default(ACTIVE)
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  installments DebtInstallment[]
  payments     DebtPayment[]

  @@index([userId, type, status])
  @@map("debts")
}

model DebtInstallment {
  id               String   @id @default(cuid())
  debtId           String
  installmentNo    Int
  principalPortion Decimal  @db.Decimal(15, 2)
  interestPortion  Decimal  @db.Decimal(15, 2)
  totalPayment     Decimal  @db.Decimal(15, 2)
  outstandingAfter Decimal  @db.Decimal(15, 2)
  dueDate          DateTime
  paidDate         DateTime?
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())

  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@unique([debtId, installmentNo])
  @@index([debtId, status])
  @@map("debt_installments")
}

model DebtPayment {
  id          String   @id @default(cuid())
  debtId      String
  amount      Decimal  @db.Decimal(15, 2)
  paymentDate DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())

  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([debtId, paymentDate])
  @@map("debt_payments")
}
